#!/bin/sh
### BEGIN INIT INFO
# Provides:          custom_api
# Required-Start:    $network S50network
# Required-Stop:
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Custom REST config API
### END INIT INFO

DAEMON=/usr/bin/custom_api
PORT=8765
PIDFILE=/var/run/custom_api.pid
LOGFILE=/var/log/custom_api.log

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "custom_api already running (pid $(cat $PIDFILE))"
        return 0
    fi
    echo -n "Starting custom_api... "
    "$DAEMON" "$PORT" >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    echo "OK (pid $!, port $PORT)"
}

stop() {
    if [ ! -f "$PIDFILE" ]; then
        echo "custom_api not running"
        return 0
    fi
    echo -n "Stopping custom_api... "
    kill "$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE"
    echo "OK"
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "custom_api running (pid $(cat $PIDFILE), port $PORT)"
    else
        echo "custom_api not running"
    fi
}

case "$1" in
    start)   start   ;;
    stop)    stop    ;;
    restart) stop; sleep 1; start ;;
    status)  status  ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
